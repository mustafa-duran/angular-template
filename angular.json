{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "src/apps",
  "projects": {
    "base": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "src/apps/base",
      "sourceRoot": "src/apps/base/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/apps/base/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "src/apps/base/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/apps/base/public",
                "output": "/public"
              },
              {
                "glob": "**/*",
                "input": "assets",
                "output": "/assets"
              }
            ],
            "styles": ["src/apps/base/src/styles.css", "assets/styles/global.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "base:build:production"
            },
            "development": {
              "buildTarget": "base:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "src/apps/base/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/apps/base/public",
                "output": "/public"
              },
              {
                "glob": "**/*",
                "input": "assets",
                "output": "/assets"
              }
            ],
            "styles": ["src/apps/base/src/styles.css", "assets/styles/global.css"]
          }
        }
      }
    },
    "management": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "src/apps/management",
      "sourceRoot": "src/apps/management/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/apps/management/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "src/apps/management/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/apps/base/public",
                "output": "/public"
              },
              {
                "glob": "**/*",
                "input": "assets",
                "output": "/assets"
              }
            ],
            "styles": ["src/apps/base/src/styles.css", "assets/styles/global.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "management:build:production"
            },
            "development": {
              "buildTarget": "management:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "src/apps/management/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/apps/base/public",
                "output": "/public"
              },
              {
                "glob": "**/*",
                "input": "assets",
                "output": "/assets"
              }
            ],
            "styles": ["src/apps/base/src/styles.css", "assets/styles/global.css"]
          }
        }
      }
    },

    "core": {
      "projectType": "library",
      "root": "src/libs/core",
      "sourceRoot": "src/libs/core/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "src/libs/core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "src/libs/core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "src/libs/core/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        }
      }
    },
    "ui": {
      "projectType": "library",
      "root": "src/libs/ui",
      "sourceRoot": "src/libs/ui/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "src/libs/ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "src/libs/ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "src/libs/ui/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        }
      }
    },
    "features": {
      "projectType": "library",
      "root": "src/libs/features",
      "sourceRoot": "src/libs/features/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "src/libs/features/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "src/libs/features/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "src/libs/features/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        }
      }
    }
  }
}
