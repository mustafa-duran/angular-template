/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@core": ["./dist/core", "./src/libs/core"],
      "@ui": ["./dist/ui", "./src/libs/ui"],
      "@features": ["./dist/features", "./src/libs/features"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./src/apps/base/tsconfig.app.json"
    },
    {
      "path": "./src/apps/management/tsconfig.app.json"
    },
    {
      "path": "./src/libs/core/tsconfig.lib.json"
    },
    {
      "path": "./src/libs/core/tsconfig.spec.json"
    },
    {
      "path": "./src/libs/features/tsconfig.lib.json"
    },
    {
      "path": "./src/libs/features/tsconfig.spec.json"
    },
    {
      "path": "./src/libs/ui/tsconfig.lib.json"
    },
    {
      "path": "./src/libs/ui/tsconfig.spec.json"
    }
  ]
}
